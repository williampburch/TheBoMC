SECRET_KEY=replace-with-a-long-random-string
# Local dev example: sqlite:///buffet_club.db
# Container-on-VM example: sqlite:////app/instance/buffet_club.db
DATABASE_URL=sqlite:///buffet_club.db
ADMIN_USERNAME=admin@example.com
ADMIN_PASSWORD=change-me-now
# Optional: set to 1 once if you need startup to re-sync the existing admin password.
ADMIN_RESET_PASSWORD_ON_START=0
